<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Créer votre compte - X</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    {{-- Cette ligne magique charge votre fichier CSS via Vite --}}
      @vite(['resources/css/app.css'])
</head>
<body>

<div class="container">
    <div class="form-box">
        <h1>Créer votre compte</h1>

        <!-- Formulaire avec ID pour le JavaScript -->
        <form id="register-form">

            <label for="fullname">Nom et prénom</label>
            <input type="text" id="fullname" name="fullname" required placeholder="Votre nom complet">

            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="kakobaalexandrinspauljr@gmail.com">

            <label for="password">Mot de passe</label>
            <!-- minlength="6" empêche les mots de passe trop courts -->
            <input type="password" id="password" name="password" minlength="6" required placeholder="Minimum 6 caractères">

            <label for="day">Date de naissance</label>
            <p class="required-info">Cette information ne sera pas affichée publiquement. Confirmez votre âge, même si ce compte est pour une entreprise, un animal de compagnie ou autre chose.</p>

            <div class="dob">
                <select id="day" name="day" required>
                    <option value="">Jour</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <!-- Vos autres options de jours de 4 à 31 ici -->
                </select>

                <select id="month" name="month" required>
                    <option value="">Mois</option>
                    <option value="1">Janvier</option>
                    <option value="2">Février</option>
                    <!-- Vos autres options de mois ici -->
                </select>

                <select id="year" name="year" required>
                    <option value="">Année</option>
                    <option value="2026">2026</option>
                    <option value="2025">2025</option>
                    <!-- Vos autres options d'années ici -->
                </select>
            </div>
<!-- Ce lien permet de retourner à la page auth-client -->


            <!-- Bouton nettoyé : type "submit" obligatoire, sans le onclick intrusif -->

<button onclick="window.location.href='/profil-client'">
    Rengistrer
</button>
        </form>
    </div>
</div>
<script src="/js/script.js"></script>

</html>
