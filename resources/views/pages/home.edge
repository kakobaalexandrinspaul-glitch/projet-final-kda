<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >
  
  <title>Accueil | X Clone</title>
  
  <link
    rel="stylesheet"
    href="/css/home.css"
  >

</head>

<body>
  <div class="home-container">
   
    <aside class="sidebar-left">

      <!-- LOGO -->
      <div class="sidebar-logo">

        <img
          src="/images/icon/xlogo.svg"
          alt="X Logo"
        >

      </div>

      <!-- NAVIGATION -->
      <nav class="sidebar-nav">

        <a href="#" class="nav-item active">

          <img
            src="/images/icon/home.svg"
            alt=""
          >

          <span>Accueil</span>

        </a>

        <a href="#" class="nav-item">

          <img
            src="/images/icon/search.svg"
            alt=""
          >

          <span>Explorer</span>

        </a>

        <a href="#" class="nav-item">

          <img
            src="/images/icon/notification.svg"
            alt=""
          >

          <span>Notifications</span>

        </a>

        <a href="#" class="nav-item">

          <img
            src="/images/icon/message.svg"
            alt=""
          >

          <span>Messages</span>

        </a>

        <a href="#" class="nav-item">

          <img
            src="/images/icon/user-round-pen.svg"
            alt=""
          >

          <span>Profil</span>

        </a>

        <a href="#" class="nav-item">

          <img
            src="/images/icon/settings.svg"
            alt=""
          >

          <span>Paramètres</span>

        </a>

      </nav>

      <!-- POST BUTTON -->
      <button class="post-btn">
        Poster
      </button>

      <!-- USER -->
      <div class="sidebar-user">

        <div class="user-left">

          <img
            src="/images/default/default-avatar.png"
            alt="User"
            class="user-avatar"
          >

          <div class="user-info">

            <h4>Christian Ndaye</h4>
            <p>@christian</p>

          </div>

        </div>

      </div>

    </aside>
   
    <main class="main-feed">

      <!-- HEADER -->
      <div class="feed-header">

        <button class="feed-tab active">
          Pour vous
        </button>

        <button class="feed-tab">
          Abonnements
        </button>

      </div>

      <!-- CREATE POST -->
      <section class="create-post">

        <div class="create-post-avatar">

          <img
            src="/images/default/default-avatar.png"
            alt=""
          >

        </div>

        <div class="create-post-content">

          <textarea
            placeholder="Quoi de neuf ?"
          ></textarea>

          <div class="create-post-actions">

            <div class="post-icons">

              <img
                src="/images/icon/image.svg"
                alt=""
              >

              <img
                src="/images/icon/video.svg"
                alt=""
              >

              <img
                src="/images/icon/calendar-days.svg"
                alt=""
              >

              <img
                src="/images/icon/localisation.svg"
                alt=""
              >

            </div>

            <button class="publish-btn">
              Poster
            </button>

          </div>

        </div>

      </section>
      <section class="feed-posts">

        <!-- POST -->
        <article class="tweet-card">

          <div class="tweet-avatar">

            <img
              src="/images/default/default-avatar.png"
              alt=""
            >

          </div>

          <div class="tweet-content">

            <!-- HEADER -->
            <div class="tweet-header">

              <div class="tweet-user">

                <h4>Christian Ndaye</h4>

                <span>@christian</span>

                <span>·</span>

                <span>4h</span>

              </div>

              <button class="tweet-more">
                •••
              </button>

            </div>

            <!-- TEXT -->
            <div class="tweet-text">

              Lorem ipsum dolor sit amet,
              consectetur adipisicing elit.

            </div>

            <!-- IMAGE -->
            <div class="tweet-image">

              <img
                src="/images/posts/post-1.jpg"
                alt=""
              >

            </div>

            <!-- ACTIONS -->
            <div class="tweet-actions">

              <button>

                <img
                  src="/images/icon/message-circle-more.svg"
                  alt=""
                >

                <span>24</span>

              </button>

              <button>

                <img
                  src="/images/icon/repeat-2.svg"
                  alt=""
                >

                <span>12</span>

              </button>

              <button>

                <img
                  src="/images/icon/like.svg"
                  alt=""
                >

                <span>1.2K</span>

              </button>

              <button>

                <img
                  src="/images/icon/share-2.svg"
                  alt=""
                >

              </button>

            </div>

          </div>

        </article>

      </section>

    </main>
   
    <aside class="sidebar-right">

      <!-- SEARCH -->
      <div class="right-search">

        <img
          src="/images/icon/search.svg"
          alt=""
        >

        <input
          type="text"
          placeholder="Rechercher"
        >

      </div>

      <!-- TRENDS -->
      <section class="trends-box">

        <h3>Ce qui se passe</h3>

        <div class="trend-item">

          <span>Tendance · RDC</span>

          <h4>Lubumbashi</h4>

          <p>12K publications</p>

        </div>

        <div class="trend-item">

          <span>Actualité</span>

          <h4>OpenAI</h4>

          <p>4 523 publications</p>

        </div>

      </section>

      <!-- FOLLOW -->
      <section class="follow-box">

        <h3>Suggestions</h3>

        <div class="follow-item">

          <div class="follow-user">

            <img
              src="/images/default/default-avatar.png"
              alt=""
            >

            <div>

              <h4>Sarah Mbuyi</h4>
              <p>@sarah</p>

            </div>

          </div>

          <button>
            Suivre
          </button>

        </div>

      </section>

    </aside>

  </div>

</body>

</html>
