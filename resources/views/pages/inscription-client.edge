<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion à X</title>
  <link rel="stylesheet" href="style.css">
  {{--cette ligne magique charge votre fichier css via vite --}}
    @vite(['resources/css/app.css'])
</head>
<body>

  <div class="login-container">

    <h1>Connectez-vous à X</h1>

    <button class="btn google">
      <img src="assets/oip__1_-1.webp" alt="Google">
      Se connecter avec Google
    </button>

    <button class="btn apple">
      <img src="assets/t__l__charger__2_.webp" alt="Apple">
      Se connecter avec Apple
    </button>

    <div class="divider">ou</div>

    <!-- Encapsulation dans un formulaire avec ID pour le JavaScript -->
    <form id="login-form">
      <div class="input-group">
        <label for="login-email">Adresse e-mail</label>
        <input type="email" id="login-email" name="email" placeholder="Adresse e-mail" required>
      </div>

      <div class="input-group">
        <label for="login-password">Mot de passe</label>
        <input type="password" id="login-password" name="password" placeholder="Mot de passe" required>
      </div>

      <!-- Suppression du onclick de redirection forcée -->
      <button type="submit" class="btn next">Se connecter</button>
    </form>

    <button class="forgot-password">Mot de passe oublié ?</button>

<div class="login-footer">
    <p class="signup">Vous n'avez pas de compte ? <a href="profil-client.html">Inscrivez-vous</a></p>
</div>

<script src="/js/script.js"></script>
</body>
</html>
